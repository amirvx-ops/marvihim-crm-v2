{
  "accentColor": "{{appsmith.theme.colors.primaryColor}}",
  "allowScroll": false,
  "animateLoading": true,
  "borderRadius": "{{appsmith.theme.borderRadius.appBorderRadius}}",
  "bottomRow": 66,
  "boxShadow": "{{appsmith.theme.boxShadow.appBoxShadow}}",
  "chartData": {
    "new_leads": {
      "data": "{{chart_monthly_trend.data.map(r => ({x: r.month, y: Number(r.new_leads)}))}}",
      "seriesName": "לידים חדשים"
    },
    "closings": {
      "data": "{{chart_monthly_trend.data.map(r => ({x: r.month, y: Number(r.closings)}))}}",
      "seriesName": "סגירות"
    },
    "ported": {
      "data": "{{chart_monthly_trend.data.map(r => ({x: r.month, y: Number(r.ported)}))}}",
      "seriesName": "נוידו"
    }
  },
  "chartName": "מגמה חודשית (12 חודשים)",
  "chartType": "LINE_CHART",
  "customFusionChartConfig": {
    "type": "column2d",
    "dataSource": {
      "chart": {},
      "data": []
    }
  },
  "dynamicBindingPathList": [
    { "key": "accentColor" },
    { "key": "borderRadius" },
    { "key": "boxShadow" },
    { "key": "chartData.new_leads.data" },
    { "key": "chartData.closings.data" },
    { "key": "chartData.ported.data" }
  ],
  "dynamicHeight": "FIXED",
  "fontFamily": "{{appsmith.theme.fontFamily.appFont}}",
  "isLoading": false,
  "isVisible": true,
  "labelOrientation": "AUTO",
  "leftColumn": 0,
  "minWidth": 450,
  "needsErrorInfo": false,
  "parentColumnSpace": 17.9375,
  "parentId": "0",
  "parentRowSpace": 10,
  "renderMode": "CANVAS",
  "responsiveBehavior": "fill",
  "rightColumn": 64,
  "setAdaptiveYMin": false,
  "topRow": 40,
  "type": "CHART_WIDGET",
  "version": 1,
  "widgetId": "db_chart_mth",
  "widgetName": "Chart_MonthlyTrend",
  "xAxisName": "חודש",
  "yAxisName": "כמות"
}
