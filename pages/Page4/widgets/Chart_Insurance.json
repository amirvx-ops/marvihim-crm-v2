{
  "accentColor": "{{appsmith.theme.colors.primaryColor}}",
  "allowScroll": false,
  "animateLoading": true,
  "borderRadius": "{{appsmith.theme.borderRadius.appBorderRadius}}",
  "bottomRow": 92,
  "boxShadow": "{{appsmith.theme.boxShadow.appBoxShadow}}",
  "chartData": {
    "leads": {
      "data": "{{chart_insurance_company.data.map(r => ({x: r.company, y: Number(r.leads)}))}}",
      "seriesName": "לידים"
    },
    "closings": {
      "data": "{{chart_insurance_company.data.map(r => ({x: r.company, y: Number(r.closings)}))}}",
      "seriesName": "סגירות"
    }
  },
  "chartName": "הראל vs הפניקס",
  "chartType": "BAR_CHART",
  "customFusionChartConfig": {
    "type": "column2d",
    "dataSource": {
      "chart": {},
      "data": []
    }
  },
  "dynamicBindingPathList": [
    { "key": "accentColor" },
    { "key": "borderRadius" },
    { "key": "boxShadow" },
    { "key": "chartData.leads.data" },
    { "key": "chartData.closings.data" }
  ],
  "dynamicHeight": "FIXED",
  "fontFamily": "{{appsmith.theme.fontFamily.appFont}}",
  "isLoading": false,
  "isVisible": true,
  "labelOrientation": "AUTO",
  "leftColumn": 0,
  "minWidth": 450,
  "needsErrorInfo": false,
  "parentColumnSpace": 17.9375,
  "parentId": "0",
  "parentRowSpace": 10,
  "renderMode": "CANVAS",
  "responsiveBehavior": "fill",
  "rightColumn": 32,
  "setAdaptiveYMin": false,
  "topRow": 66,
  "type": "CHART_WIDGET",
  "version": 1,
  "widgetId": "db_chart_ins",
  "widgetName": "Chart_Insurance",
  "xAxisName": "חברה",
  "yAxisName": "כמות"
}
